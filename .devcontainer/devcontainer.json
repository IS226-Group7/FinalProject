{
    "name": "PHP & MySQL (Filament ITAM)",
    "image": "mcr.microsoft.com/devcontainers/php:1-8.3-bullseye",
    "features": {
        "ghcr.io/devcontainers/features/mysql:1.0.8": {
            "databaseName": "laravel",
            "rootPassword": "root"
        },
        "ghcr.io/devcontainers/features/node:1": {}
    },
    "containerEnv": {
        "DB_HOST": "127.0.0.1",
        "DB_PORT": "3306",
        "DB_DATABASE": "laravel",
        "DB_USERNAME": "root",
        "DB_PASSWORD": "root"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "onecentlin.laravel-blade",
                "amiralizadeh9480.laravel-extra-intellisense",
                "bmewburn.vscode-intelephense-client",
                "mtxr.sqltools",
                "mtxr.sqltools-driver-mysql"
            ]
        }
    },
    "forwardPorts": [8000, 3306],
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y libicu-dev && sudo docker-php-ext-configure intl && sudo docker-php-ext-install intl && composer install && cp .env.example .env || true && php artisan key:generate"
}